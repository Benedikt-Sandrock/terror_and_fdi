{txt}(15 observations deleted)

{com}. drop if ISO3 == "NPL" & year <1996
{txt}(26 observations deleted)

{com}. drop if ISO3 == "SDN" & year <1972
{txt}(2 observations deleted)

{com}. drop if ISO3 == "TLS" & year <2005
{txt}(35 observations deleted)

{com}. drop if ISO3 == "SYR" & (year <1972 | year > 2011)
{txt}(11 observations deleted)

{com}. drop if ISO3 =="ALB" & year < 1992
{txt}(22 observations deleted)

{com}. drop if ISO3 == "BLZ" & year < 1984 
{txt}(14 observations deleted)

{com}. 
. *interpolate countries
. bysort ccode (year): ipolate fdi_inflow_percent year, gen(fdi_temp)
{txt}(1167 missing values generated)

{com}. gen has_interpolation = 0
{txt}
{com}. replace has_interpolation = 1 if missing(fdi_inflow_percent) & !missing(fdi_temp)
{txt}(13 real changes made)

{com}. replace fdi_inflow_percent = fdi_temp if missing(fdi_inflow_percent)
{txt}(13 real changes made)

{com}. bysort ccode: egen interpolation_num = sum(has_interpolation)
{txt}
{com}. drop fdi_temp
{txt}
{com}. 
