. *===============================================================================
. * 2.0 COVERAGE DIAGNOSTICS
. *===============================================================================
. * Check for gaps in the FDI data
. bysort ccode (year): egen first_data = min(cond(!missing(fdi_inflow_percent), year, .))
{txt}(561 missing values generated)

{com}. bysort ccode (year): egen last_data  = max(cond(!missing(fdi_inflow_percent), year, .))
{txt}(561 missing values generated)

{com}. 
. gen gap_in_country = 0
{txt}
{com}. bysort ccode: replace gap_in_country = 1 if missing(fdi_inflow_percent) & year > first_data & year < last_data
{txt}(77 real changes made)

{com}. bysort ccode: egen has_gaps = sum(gap_in_country)
{txt}
{com}. 
. drop first_data last_data gap_in_country
{txt}
{com}. 
. *drop country-periods if there are too many gaps / not sufficient data to interpolate
. drop if ISO3 == "BTN" & year < 2002
{txt}(32 observations deleted)

{com}. drop if ISO3 == "DJI" & year < 1987
{txt}(17 observations deleted)

{com}. drop if ISO3 == "ERI" & (year < 1996 | year > 2011)
{txt}(12 observations deleted)

{com}. drop if ISO3 == "GEO" & year < 1997
{txt}(6 observations deleted)

{com}. drop if ISO3 == "GNB" & year < 1984
{txt}(14 observations deleted)

{com}. drop if ISO3 == "KHM" & year < 1992
{txt}(22 observations deleted)

